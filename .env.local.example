# URL of the deployed RAG knowledge base HTTP API
# Leave unset during local development to use mock responses
RAG_API_URL=https://your-rag-service.example.com

# URL of the suarakita dashboard (for case/improvement counts)
# Leave unset to show — instead of numbers
DASHBOARD_URL=http://localhost:3001

# YouTube Live URL — accepts watch URL, youtu.be link, embed URL, or bare video ID
NEXT_PUBLIC_YOUTUBE_LIVE_URL=https://www.youtube.com/watch?v=your-video-id
